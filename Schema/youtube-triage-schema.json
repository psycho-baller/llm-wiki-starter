{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "relevance_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "actionability_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "novelty_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "credibility_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "density_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "personal_resonance_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "redundancy_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "time_cost": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "clickbait_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "decision": {
      "type": "string",
      "enum": ["skip", "watch", "skim", "process", "later"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "triage_reason": {
      "type": "string"
    },
    "expected_gain": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "maxLength": 600
    },
    "skim_plan": {
      "type": "string",
      "maxLength": 600
    },
    "what_to_look_for": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "string",
        "pattern": "^(approx\\. )?(\\d{1,2}:)?\\d{1,2}:\\d{2}(\\s*-\\s*(\\d{1,2}:)?\\d{1,2}:\\d{2})?\\s+-\\s+.+"
      }
    },
    "things": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "people": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "places": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "things_and_concepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["people", "places", "things_and_concepts"]
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "maxLength": 600
      }
    }
  },
  "required": [
    "relevance_score",
    "actionability_score",
    "novelty_score",
    "credibility_score",
    "density_score",
    "personal_resonance_score",
    "redundancy_risk",
    "time_cost",
    "clickbait_risk",
    "decision",
    "confidence",
    "triage_reason",
    "expected_gain",
    "summary",
    "skim_plan",
    "what_to_look_for",
    "things",
    "next_actions"
  ]
}
